# Postgres connection string (self-hosted Postgres)
DATABASE_URL=postgres://user:pass@localhost:5432/faktura

# Better Auth secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here

# Public app URL (used as Better Auth baseURL)
PUBLIC_APP_URL=http://localhost:5173

# Cloudflare R2 storage (invoice PDFs and logos) is configured via the
# `INVOICES_BUCKET` binding in wrangler.jsonc — no environment variable needed.
# Create the bucket with:
#   npx wrangler r2 bucket create skabelontilfaktura-invoices

# Secret token required to invoke the /api/jobs/reminders cron route.
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here

# "From" address for outgoing transactional email (payment reminders, etc.).
# Used by src/lib/server/email/client.ts. Wire to Cloudflare Email Service later.
EMAIL_FROM=noreply@skabelontilfaktura.dk
